# ===================================================
# NGO Scholarship System — Environment Variables
# Copy this to .env.local and fill in all values
# NEVER commit .env.local to version control
# ===================================================

# --- Supabase (get from supabase.com project settings) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # NEVER expose this to frontend

# --- Resend Email (get from resend.com) ---
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@yourdomain.org
ADMIN_EMAIL=admin@yourdomain.org

# --- App Configuration ---
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app   # No trailing slash
